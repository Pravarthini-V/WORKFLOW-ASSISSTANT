# Workflow Assistant - Complete Git Ignore File
# ======================================================================

# ────────────────────────── DEPENDENCIES ──────────────────────────
# Node modules (NEVER commit these - they're huge!)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ────────────────────────── ENVIRONMENT VARIABLES ──────────────────────────
# CONTAINS SECRETS - NEVER COMMIT!
.env
.env.local
.env.development
.env.production
.env.test
.env.staging
.env.*.local
*.env
!.env.example          # Keep this template file
!.env.sample

# ────────────────────────── BACKEND SPECIFIC ──────────────────────────
# Express/Node.js backend
backend/node_modules/
backend/package-lock.json
backend/yarn.lock
backend/dist/
backend/build/
backend/logs/
backend/*.log
backend/.env
backend/.env.local
backend/.env.production
backend/coverage/
backend/.nyc_output/
backend/*.pid
backend/*.seed
backend/*.pid.lock

# ────────────────────────── FRONTEND SPECIFIC ──────────────────────────
# React/Vite frontend
src/node_modules/
src/package-lock.json
src/yarn.lock
dist/
build/
out/
*.tsbuildinfo
.eslintcache
.cache/
.temp/
public/assets/
src/coverage/
src/.nyc_output/

# ────────────────────────── DATABASE ──────────────────────────
