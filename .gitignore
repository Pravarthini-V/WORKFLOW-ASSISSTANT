*.db
*.sqlite
*.sqlite3
*.db-journal
*.wal
*.sql
*.dump
*.backup
*.bak
database.sqlite
database/*.db
database/backups/
database/data/
database/migrations/*.js
database/seeds/*.js
*.db-wal
*.db-shm
!database/schema.sql    # Keep schema but not data
!database/migrations/README.md

